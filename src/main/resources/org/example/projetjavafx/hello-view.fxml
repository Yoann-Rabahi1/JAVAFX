<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.projetjavafx.controller.MainController"
      prefHeight="850.0" prefWidth="1250.0" spacing="0"
      style="-fx-background-color: #f5f5f5;">

    <MenuBar>
        <Menu text="Fichier">
            <MenuItem text="Quitter" onAction="#onQuitter"/>
        </Menu>
    </MenuBar>

    <SplitPane orientation="VERTICAL" dividerPositions="0.5" VBox.vgrow="ALWAYS" style="-fx-box-border: transparent;">
        <items>

            <SplitPane dividerPositions="0.35" style="-fx-box-border: transparent;">
                <items>
                    <VBox style="-fx-padding: 10; -fx-background-color: #ffffff;">
                        <Label text="COLONNE HISTOIRES" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 10 0;"/>
                        <fx:include fx:id="histoireView" source="histoire-view.fxml" VBox.vgrow="ALWAYS" />
                    </VBox>

                    <VBox style="-fx-padding: 10; -fx-background-color: #ffffff;">
                        <Label text="ZONE PERSONNAGES" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 5 0;"/>
                        <fx:include fx:id="personnageView" source="personnage-view.fxml" VBox.vgrow="ALWAYS" />
                    </VBox>
                </items>
            </SplitPane>

            <VBox style="-fx-padding: 10; -fx-background-color: #ffffff;">
                <Label text="ZONE SCÈNES &amp; PRÉSENCES" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 5 0;"/>
                <fx:include fx:id="sceneView" source="scene-view.fxml" VBox.vgrow="ALWAYS" />
            </VBox>

        </items>
    </SplitPane>
</VBox>