<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.projetjavafx.controller.SceneController"
      spacing="15" style="-fx-padding: 2;">

    <VBox spacing="5" prefWidth="250.0" maxWidth="300.0" HBox.hgrow="ALWAYS">
        <Label text="Scènes de l'histoire :" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        <ComboBox fx:id="ComboHistoires" managed="false" visible="false" />

        <ListView fx:id="ListScenes" VBox.vgrow="ALWAYS" />
    </VBox>

    <VBox spacing="8" HBox.hgrow="ALWAYS">
        <Label text="Détails de la scène sélectionnée" style="-fx-font-weight: bold; -fx-font-size: 12px;" />

        <GridPane hgap="8" vgap="6" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="60.0" vgrow="ALWAYS" />
            </rowConstraints>
            <children>
                <TextField fx:id="txtFieldTitre" promptText="Titre de la scène" GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.columnSpan="2"/>

                <TextField fx:id="txtFieldLieu" promptText="Lieu (Ex: Château, Forêt...)" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtFieldMoment" promptText="Moment (Ex: Nuit, An 400...)" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <TextField fx:id="txtFieldPosition" promptText="Position (Chiffre unique)" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="ComboStatut" promptText="Statut" prefWidth="200.0" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <TextArea fx:id="txtAreaContenu" promptText="Contenu de la scène / Histoire..." prefHeight="70.0" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
            </children>
        </GridPane>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Button text="Ajouter" onAction="#onAjouterScene" prefWidth="80.0" />
            <Button text="Modifier" onAction="#onModifierScene" prefWidth="80.0" />
            <Button text="Supprimer" onAction="#onSupprimerScene" prefWidth="80.0" />
        </HBox>
    </VBox>

    <VBox spacing="5" prefWidth="280.0" maxWidth="320.0" HBox.hgrow="ALWAYS">
        <Label text="Personnages présents dans cette scène" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
        <ListView fx:id="ListPersonnagesPresents" VBox.vgrow="ALWAYS" />

        <HBox spacing="5">
            <ComboBox fx:id="ComboAjoutPersonnage" promptText="Sélectionner..." HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
            <Button text="Associer" onAction="#onAssocierPersonnage" minWidth="75.0" />
        </HBox>
        <Button text="Retirer le personnage sélectionné" onAction="#onRetirerPersonnage" maxWidth="1.7976931348623157E308" style="-fx-text-fill: #c0392b; -fx-font-size: 11px;" />
    </VBox>

</HBox>