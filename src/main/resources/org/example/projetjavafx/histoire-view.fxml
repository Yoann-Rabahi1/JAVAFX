<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.projetjavafx.controller.HistoireController"
      spacing="8" style="-fx-padding: 2;">

   <ListView fx:id="ListHistoires" VBox.vgrow="ALWAYS" prefHeight="180.0" />

   <GridPane hgap="8" vgap="6">
      <columnConstraints>
         <ColumnConstraints prefWidth="60.0" />
         <ColumnConstraints hgrow="ALWAYS" />
      </columnConstraints>
      <children>
         <Label text="Titre :" GridPane.rowIndex="0" GridPane.columnIndex="0" />
         <TextField fx:id="txtFieldTitre" promptText="Titre de l'histoire" GridPane.rowIndex="0" GridPane.columnIndex="1" />

         <Label text="Auteur :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
         <TextField fx:id="txtFieldAuteur" promptText="Nom de l'auteur" GridPane.rowIndex="1" GridPane.columnIndex="1" />

         <Label text="Résumé :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
         <TextArea fx:id="txtAreaResumer" promptText="Résumé global..." prefHeight="70.0" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" />
      </children>
   </GridPane>

   <HBox spacing="8" alignment="CENTER_RIGHT">
      <Button text="Créer" onAction="#onAjouterHistoire" prefWidth="75.0" />
      <Button text="Modifier" onAction="#onModifierHistoire" prefWidth="75.0" />
      <Button text="Supprimer" onAction="#onSupprimerHistoire" prefWidth="85.0" />
   </HBox>
</VBox>