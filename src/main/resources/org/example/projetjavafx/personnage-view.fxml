<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.projetjavafx.controller.PersonnageController"
      spacing="8" style="-fx-padding: 2;">

   <HBox spacing="10" alignment="CENTER_LEFT">
      <Label text="Casting (Sélectionnez une histoire) :" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
      <Region HBox.hgrow="ALWAYS" />
      <ComboBox fx:id="ComboHistoires" promptText="Choisir une histoire..." prefWidth="220.0" />
   </HBox>

   <ListView fx:id="ListPersonnages" VBox.vgrow="ALWAYS" prefHeight="120.0" />

   <GridPane hgap="8" vgap="6">
      <columnConstraints>
         <ColumnConstraints prefWidth="80.0" />
         <ColumnConstraints hgrow="ALWAYS" />
      </columnConstraints>
      <children>
         <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0" />
         <TextField fx:id="txtFieldNomPerso" promptText="Nom du personnage" GridPane.rowIndex="0" GridPane.columnIndex="1" />

         <Label text="Rôle :" GridPane.rowIndex="1" GridPane.columnIndex="0" />
         <TextField fx:id="txtFieldRolePerso" promptText="Rôle (Principal, Secondaire...)" GridPane.rowIndex="1" GridPane.columnIndex="1" />

         <Label text="Description :" GridPane.rowIndex="2" GridPane.columnIndex="0" />
         <TextArea fx:id="txtAreaDescPerso" promptText="Traits, background..." prefHeight="65.0" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" />
      </children>
   </GridPane>

   <HBox spacing="8" alignment="CENTER_RIGHT">
      <Button text="Ajouter au casting" onAction="#onAjouterPersonnage" />
      <Button text="Modifier" onAction="#onModifierPersonnage" prefWidth="80.0" />
      <Button text="Supprimer" onAction="#onSupprimerPersonnage" prefWidth="80.0" />
   </HBox>
</VBox>